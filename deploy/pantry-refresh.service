[Unit]
Description=Pantry Display daily e-paper refresh

[Service]
Type=oneshot
User=pi
WorkingDirectory=/home/pi/pantry-display
Environment=PATH=/home/pi/pantry-display/.venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
ExecStart=/home/pi/pantry-display/.venv/bin/python scripts/daily_refresh.py
